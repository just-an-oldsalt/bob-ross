# ─── Bob Ross 🎨 — Landscape MCP config ─────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# Base URL of your Landscape server (no trailing /api/ — we add it).
#   SaaS:        https://landscape.canonical.com
#   Self-hosted: https://landscape.your-domain.com
BOBROSS_LANDSCAPE_URL=https://landscape.example.com

# ── Auth: pick ONE mode ─────────────────────────────────────────────
# Mode A — REST bearer token (self-hosted 24.04+ / newer API):
BOBROSS_API_TOKEN=

# Mode B — Legacy HMAC query API (SaaS + older self-hosted):
BOBROSS_ACCESS_KEY=
BOBROSS_SECRET_KEY=

# ── Connection ──────────────────────────────────────────────────────
# Verify TLS certs. Set to false ONLY for a dev box with a self-signed
# cert — you'll get a loud warning. Never false in production.
BOBROSS_TLS_VERIFY=true
BOBROSS_REQUEST_TIMEOUT=30

# ── Safety (secure by default) ──────────────────────────────────────
# Read-only mode blocks ALL write/destructive tools. Default: true.
BOBROSS_READ_ONLY=true
# Even with read_only=false, writes stay blocked unless this is true.
BOBROSS_ALLOW_WRITES=false
# How long a dry-run confirm token stays valid (seconds).
BOBROSS_CONFIRM_TTL_SECONDS=300
# Where to append the JSONL audit log of every action taken.
BOBROSS_AUDIT_LOG_PATH=audit.log.jsonl
